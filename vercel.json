{
  "outputDirectory": "dist",
  "build": {
    "env": {
      "UV_LINK_MODE": "copy"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/ai",
      "destination": "/api/index.py"
    },
    {
      "source": "/speaker/:user_id",
      "destination": "/api/index.py"
    },
    {
      "source": "/listener/:user_id",
      "destination": "/api/index.py"
    },
    {
      "source": "/match",
      "destination": "/api/index.py"
    },
    {
      "source": "/leave/:user_id",
      "destination": "/api/index.py"
    }
  ]
}
